PORT=2999
DOMAIN=njump.me
DEFAULT_LANGUAGE=en

# Optional canonical override for relay/NIP-11 responses. Leave empty to derive from request host.
SERVICE_URL=

# Storage controls for the shared cache.
EVENT_STORE_MAP_SIZE_GB=64
CACHE_RETENTION_DAYS=7

# Backpressure controls.
ENABLE_QUEUE_MIDDLEWARE=true
METADATA_FETCH_CONCURRENCY=4
METADATA_FETCH_TIMEOUT_MS=3000

# Optional relay discovery from nip-66 relay status events (default: Nostr.watch relays).
ENABLE_RELAY_DISCOVERY=false
# Comma-separated relay(s) for NIP-66 discovery, or HTTP(S) API endpoints.
# Prefer websocket sources first (`wss://...`) as they are the primary supported path.
# HTTP(S) discovery is kept for compatibility only and depends on legacy nostr.watch-style endpoints.
RELAY_DISCOVERY_URL=wss://relay.nostr.watch,wss://relaypag.es,wss://monitorlizard.nostr1.com
RELAY_DISCOVERY_MAX_RELAYS=24
RELAY_DISCOVERY_REFRESH_SECONDS=900
RELAY_DISCOVERY_TIMEOUT_MS=3000

# Optional allow-list of languages across all domains.
# ALLOWED_LANGUAGE=en,ar,he,tr,fa,es,pt

# TRUSTED_PUBKEYS=npub1...,npub1...
